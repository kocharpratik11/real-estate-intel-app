{
  "expo": {
    "name": "Asset Brain",
    "slug": "asset-brain",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rei",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.assetbrain.app",
      "newArchEnabled": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Asset Brain uses Face ID to quickly and securely unlock your portfolio.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.assetbrain.app",
      "versionCode": 1,
      "newArchEnabled": true
    },
    "updates": {
      "url": "https://u.expo.dev/d5940bc8-2ee5-4fe5-9623-ae41404b97bb",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#3B82F6"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F172A",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "rei-cd",
          "project": "react-native"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d5940bc8-2ee5-4fe5-9623-ae41404b97bb"
      }
    },
    "owner": "kocharpratik11"
  }
}
